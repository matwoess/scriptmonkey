{
  "manifest_version": 3,
  "name": "Scriptmonkey",
  "version": "0.2.0",
  "description": "Lightweight user script manager.",
  "permissions": ["storage", "tabs", "userScripts"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scriptmonkey"
  }
}
