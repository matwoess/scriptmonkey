{
	"name": "scriptmonkey",
	"version": "1.0.0",
	"description": "Lightweight Manifest V3 Chrome extension for managing user scripts — like Tampermonkey, but local and minimal.",
	"main": "background.js",
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"postinstall": "lefthook install"
	},
	"repository": {
		"type": "git",
		"url": "git+https://mathiaswoess@github.com/mathiaswoess/Scriptmonkey.git"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"type": "module",
	"bugs": {
		"url": "https://github.com/mathiaswoess/Scriptmonkey/issues"
	},
	"homepage": "https://github.com/mathiaswoess/Scriptmonkey#readme",
	"dependencies": {
		"react": "^19.2.6",
		"react-dom": "^19.2.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@crxjs/vite-plugin": "^2.0.0-beta.33",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/chrome": "^0.1.42",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"jsdom": "^29.1.1",
		"lefthook": "^2.1.6",
		"typescript": "^6.0.3",
		"vite": "^8.0.12",
		"vitest": "^4.1.6"
	}
}
